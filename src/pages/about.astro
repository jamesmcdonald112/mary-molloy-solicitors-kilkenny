---
import TrustStripSection from "../components/buying-and-selling-property/TrustStripSection.astro";
import CtaSection from "../components/shared/CtaSection.astro";
import OurTeamSection from "../components/shared/OurTeamSection.astro";
import { propertyPageContent } from "../config/content/property";
import { teamSectionContent } from "../config/content/team";
import { aboutPageContent } from "../config/content/about";
import { firm } from "../config/firm";
import { getLawFirmStructuredData } from "../config/structured-data";
import BaseLayout from "../layouts/BaseLayout.astro";

const structuredData = getLawFirmStructuredData();
---

<BaseLayout
  title={`${aboutPageContent.seo.title} | ${firm.companyName}`}
  description={aboutPageContent.seo.description}
  canonicalPath={aboutPageContent.seo.canonicalPath}
  ogType="website"
  structuredData={structuredData}
>
  <TrustStripSection
    trustStrip={propertyPageContent.trustStrip}
    heroImage={propertyPageContent.hero.image}
  />
  <OurTeamSection teamSection={teamSectionContent} />
  <CtaSection />
</BaseLayout>
