---
import ServiceArticle from "../../components/services/ServiceArticle.astro";
import ServiceHero from "../../components/services/ServiceHero.astro";
import ServiceMidCta from "../../components/services/ServiceMidCta.astro";
import ServiceProcess from "../../components/services/ServiceProcess.astro";
import CtaSection from "../../components/shared/CtaSection.astro";
import FaqSection from "../../components/shared/FaqSection.astro";
import TrustStrip from "../../components/shared/TrustStrip.astro";
import { services } from "../../config/services";
import { getLawFirmStructuredData } from "../../config/structured-data";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
	return services.map((service) => ({
		params: { slug: service.slug },
		props: { service },
	}));
}

const { service } = Astro.props;
const structuredData = getLawFirmStructuredData();
---

<BaseLayout
	title={service.seo.title}
	description={service.seo.description}
	canonicalPath={service.seo.canonicalPath}
	ogType="website"
	structuredData={structuredData}
>
	<ServiceHero title={service.hero.title} subtitle={service.hero.subtitle} image={service.image} imageClass={service.imageClass} />
	<ServiceArticle
		eyebrow={service.article.eyebrow}
		title={service.article.title}
		intro={service.article.intro}
		blocks={service.article.blocks}
	/>
	<ServiceMidCta heading={service.midCta} />
	<ServiceProcess steps={service.process} />
	<TrustStrip
		title={service.trustStrip.title}
		columns={service.trustStrip.columns}
		stats={service.trustStrip.stats}
	/>
	<CtaSection variant="dark" title={service.cta.title} body={service.cta.description} />
	<FaqSection faqs={service.faqs} />
</BaseLayout>
