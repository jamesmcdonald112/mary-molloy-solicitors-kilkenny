---
import phoneIcon from "../assets/ctas/phoneIcon.svg?raw";
import checkCircleIcon from "../assets/icons/checkCircleIcon.svg?raw";
import PhoneNumber from "../components/shared/PhoneNumber.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import { thankYouContent } from "../config/content/thank-you";
import { firm } from "../config/firm";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title={`${thankYouContent.seo.title} | ${firm.companyName}`}
	description={thankYouContent.seo.description}
	noIndex={true}
>
	<section class="bg-bg py-24 sm:py-32 lg:py-48">
		<div class="container-page">
			<div class="mx-auto max-w-2xl text-center">
				<span
					aria-hidden="true"
					class="mb-8 block size-40 mx-auto text-success [&_svg]:size-full"
					set:html={checkCircleIcon}
				/>
				<h1 class="text-4xl font-semibold tracking-tight text-text sm:text-5xl">
					{thankYouContent.heading}
				</h1>
				<p class="mt-6 text-lg/8 text-text-muted">
					{thankYouContent.body}
				</p>
				<div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
					<ButtonLink href={thankYouContent.href} variant="solid" size="md" block={true}>
						Back to home
					</ButtonLink>
					<PhoneNumber
						phoneHref={firm.phone.phoneHref}
						phoneIcon={phoneIcon}
						phoneDisplay={firm.phone.display}
						size="md"
						iconHeight="h-4"
						class="inline-flex justify-center w-full sm:w-fit
              px-3.5 py-2.5
              bg-transparent hover:bg-accent-hover
              text-text hover:text-text-on-accent
              rounded-md border border-btn-border hover:border-accent-hover
              transition-colors duration-200"
					/>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
