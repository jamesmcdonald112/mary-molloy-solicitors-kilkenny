---
import ContactPageContent from "../components/contact/ContactPageContent.astro";
import { firm } from "../config/firm";
import { getLawFirmStructuredData } from "../config/seo";
import { pageSeo } from "../config/seo/pages";
import ContactForm from "../features/contact-form/components/ContactForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = false;

const structuredData = getLawFirmStructuredData();
---

<BaseLayout
  title={`${pageSeo.contact.title} | ${firm.companyName}`}
  description={pageSeo.contact.description}
  canonicalPath={pageSeo.contact.canonicalPath}
  structuredData={structuredData}
>
  <ContactPageContent>
    <ContactForm />
  </ContactPageContent>
</BaseLayout>
