---
import { actions, isInputError } from "astro:actions";
import { ClientRouter } from "astro:transitions";
import chevronDownIcon from "../../../assets/icons/chevronDownIcon.svg?raw";
import FieldError from "../../../components/ui/FieldError.astro";
import FormField from "../../../components/ui/FormField.astro";
import { CONTACT_FIELD_LIMITS } from "../config/contact-field-limits";
import { CONTACT_SERVICES } from "../config/contact-services";

const result = Astro.getActionResult(actions.contact);
const error = result?.error;

const fieldErrors = isInputError(error) ? error.fields : {};

// Shared base styles for select and textarea (inputs use FormField component)
const selectClass = [
	"block w-full rounded-md appearance-none",
	"px-3.5 py-2 pr-11",
	"text-base text-text bg-input-bg",
	"focus-ring-input",
].join(" ");

const textareaClass = [
	"block w-full rounded-md",
	"px-3.5 py-2",
	"text-base text-text bg-input-bg",
	"placeholder:text-text-muted",
	"focus-ring-input",
].join(" ");
---

<ClientRouter />

<!-- ── Contact form ───────────────────────────────────────────── -->
<form
    action={actions.contact}
    method="POST"
    class="px-6 lg:px-8
      lg:py-48
      pt-20 
      pb-24 sm:pb-32"
  >
    <div class="max-w-xl lg:max-w-lg
      mx-auto lg:mr-0">
      <div class="flex flex-col gap-y-6">

        <!-- Name -->
        <FormField
          id="name"
          name="name"
          label="Name"
          type="text"
          autocomplete="name"
          placeholder="John Doe"
          required error={fieldErrors.name?.join(", ")}
          />

        <!-- Email -->
        <FormField
          id="email"
          name="email"
          label="Email"
          type="email"
          autocomplete="email"
          placeholder="johndoe@example.com"
          required error={fieldErrors.email?.join(", ")}
          />

        <!-- Phone -->
        <FormField
          id="phone"
          name="phone"
          label="Phone"
          type="tel"
          autocomplete="tel"
          placeholder="085 123 4567"
          required error={fieldErrors.phone?.join(", ")}
          />

        <!-- Service (custom: needs chevron icon overlay) -->
        <div>
          <label for="service" class="block text-sm/6 font-semibold text-text">
            Service <span class="ml-0.5 text-accent" aria-hidden="true">*</span>
          </label>
          <div class="relative mt-2.5">
            <select
              transition:persist
              id="service"
              name="service"
              class={selectClass}
            >
              <option value="">Select a legal service</option>
              {CONTACT_SERVICES.map((area) => (
                <option value={area}>{area}</option>
              ))}
            </select>
            <!-- Chevron icon — purely decorative, positioned over the right edge -->
            <span
              aria-hidden="true"
              class="absolute right-4 top-1/2 size-4 -translate-y-1/2
                text-text-muted
                pointer-events-none "
              set:html={chevronDownIcon}
            />
            <FieldError message={fieldErrors.service?.join(", ")} />
          </div>
        </div>

        <!-- Message (custom: needs character counter) -->
        <div>
          <div class="flex items-baseline justify-between">
            <label for="message" class="block text-sm/6 font-semibold text-text">
              Message <span class="ml-1 text-xs font-normal text-text-muted">(optional)</span>
            </label>
            <span id="message-count" class="text-xs text-text-muted">
              0 / {CONTACT_FIELD_LIMITS.message.max}
            </span>
          </div>
          <div class="mt-2.5">
            <textarea
              transition:persist
              id="message"
              name="message"
              rows="4"
              maxlength={CONTACT_FIELD_LIMITS.message.max}
              aria-describedby="message-count"
              placeholder="Briefly describe how we can help you…"
              class={textareaClass}
            ></textarea>
            <FieldError message={fieldErrors.message?.join(", ")} />
          </div>
        </div>

        <!-- Honeypot (spam protection — hidden from real users, bots fill it in) -->
        <div class="hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input transition:persist id="website" type="text" name="website" tabindex="-1" autocomplete="off" />
          <p class="sr-only">{fieldErrors.website?.join(", ")}</p>
        </div>

      </div>

      <!-- Required field note -->
      <p class="mt-4 text-sm text-text-muted">
        Fields marked <span class="text-accent">*</span> are required.
      </p>

      <!-- Server error (shown when submission fails for a non-validation reason) -->
      {result?.error && !isInputError(result.error) && (
        <div class="
          mt-6
          flex items-center gap-3
          rounded-lg border border-destructive-border bg-destructive-soft
          px-4 py-3
        ">
          <span class="text-destructive" aria-hidden="true">✕</span>
          <p class="text-sm font-semibold text-destructive">
            Something went wrong. Please try again later.
          </p>
        </div>
      )}

      <!-- Submit button -->
      <div class="mt-8 flex justify-end">
        <button
          type="submit"
          class="
            rounded-md
            px-3.5 py-2.5
            text-center text-sm font-semibold
            bg-(--brand-500) text-white
            shadow-xs transition-colors duration-200
            hover:bg-accent-hover hover:text-text-on-accent
            focus-ring
            cursor-pointer"
        >
          Send message
        </button>
      </div>
    </div>
  </form>

<style>
  /* Show default option in muted colour, like other placeholder text */
  select:has(option[value=""]:checked) {
    color: var(--color-text-subtle);
  }
</style>

<script>
  import "../scripts/messageCounter";
</script>
