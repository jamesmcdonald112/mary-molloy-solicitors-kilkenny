---
import { actions, isInputError } from "astro:actions";
import chevronDownIcon from "../../../assets/icons/chevronDownIcon.svg?raw";
import { CONTACT_PRACTICE_AREAS } from "../config/contact-practice-areas";

const result = Astro.getActionResult(actions.contact);
const error = result?.error;

const fieldErrors = isInputError(error) ? error.fields : {};
const hasSuccess = !!result && !error;     // action was called + no error
const hasError = !!error;                  // any error (input or server)
const hasInputError = isInputError(error); // validation errors only

---

<form
  action={actions.contact}
  method="POST"
  class="px-6 pt-20 pb-24 sm:pb-32 lg:px-8 lg:py-48"
>
  <div class="mx-auto max-w-xl lg:mr-0 lg:max-w-lg">
    <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label for="name" class="block text-sm/6 font-semibold text-gray-900"
          >Name</label
        >
        <div class="mt-2.5">
          <input
            transition:persist
            id="name"
            type="text"
            name="name"
            autocomplete="name"
            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-gray-600"
          />
          <p class="mt-1 text-sm text-gray-500">{fieldErrors.name?.join(", ")}</p>
        </div>
      </div>

      <div class="sm:col-span-2">
        <label for="phone" class="block text-sm/6 font-semibold text-gray-900"
          >Phone</label
        >
        <div class="mt-2.5">
          <input
            transition:persist
            id="phone"
            type="tel"
            name="phone"
            autocomplete="tel"
            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-gray-600"
          />
          <p class="mt-1 text-sm text-gray-500">
            {fieldErrors.phone?.join(", ")}
          </p>
        </div>
      </div>

      <div class="sm:col-span-2">
        <label
          for="practiceArea"
          class="block text-sm/6 font-semibold text-gray-900"
          >Practice area</label
        >
        <div class="relative mt-2.5">
          <select
            transition:persist
            id="practiceArea"
            name="practiceArea"
            class="block w-full appearance-none rounded-md bg-white px-3.5 py-2 pr-11 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-gray-600"
          >
            <option value="">Select a practice area</option>
            {
              CONTACT_PRACTICE_AREAS.map((area) => (
                <option value={area}>{area}</option>
              ))
            }
          </select>
          <span
            class="pointer-events-none absolute right-4 top-1/2 size-4 -translate-y-1/2 text-gray-500"
            set:html={chevronDownIcon}
          />
          <p class="mt-1 text-sm text-gray-500">
            {fieldErrors.practiceArea?.join(", ")}
          </p>
        </div>
      </div>

      <div class="sm:col-span-2">
        <label for="message" class="block text-sm/6 font-semibold text-gray-900"
          >Message</label
        >
        <div class="mt-2.5">
          <textarea
            transition:persist
            id="message"
            name="message"
            rows="4"
            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-gray-600"
          ></textarea>
          <p class="mt-1 text-sm text-gray-500">
            {fieldErrors.message?.join(", ")}
          </p>
        </div>
      </div>

      <div class="hidden" aria-hidden="true">
        <label for="website">Website</label>
        <input
          transition:persist
          id="website"
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
        />
        <p class="sr-only">{fieldErrors.website?.join(", ")}</p>
      </div>
    </div>

    {result?.error && !isInputError(result.error) && (
      <p class="mt-4 text-sm text-gray-500">
        Something went wrong. Please try again.
      </p>
    )}
    {hasSuccess && (
      <p class="mt-4 text-sm text-gray-700">Message sent. We'll get back to you.</p>
    )}

    <div class="mt-8 flex justify-end">
      <button
        type="submit"
        class="rounded-md bg-gray-900 px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-xs hover:bg-gray-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900"
      >
        Send message
      </button>
    </div>
  </div>
</form>
