---
import { Image } from "astro:assets";
import {
	teamSectionContent as defaultTeamSectionContent,
	type TeamSectionContent,
} from "../../config/content/team";

const { teamSection = defaultTeamSectionContent } = Astro.props as {
	teamSection?: TeamSectionContent;
};
---

<div class="bg-section-base py-24 sm:py-32">
	<div class="mx-auto max-w-7xl px-6 lg:px-8">
		<div class="mx-auto max-w-2xl text-center">
			<h2
				class="text-4xl sm:text-5xl
        text-primary
        font-semibold tracking-tight text-balance"
			>
				{teamSection.title}
			</h2>
			<p class="mt-6 text-lg/8 text-text-muted">{teamSection.intro}</p>
		</div>
		<ul
			role="list"
			class="mt-20 mx-auto lg:mx-0
        max-w-2xl lg:max-w-none
        grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
        gap-x-10 gap-y-16"
		>
			{
				teamSection.members.map((member) => (
					<li>
						<Image
							src={member.photo}
							alt={member.name}
							class="size-40 md:size-48 
                rounded-full object-cover 
                ring-2 ring-border-strong "
						/>
						<div class="mt-6">
							<h3 class="text-base font-semibold tracking-tight text-primary">{member.name}</h3>
							<p class="text-sm font-semibold text-accent">{member.role}</p>
							<p class="mt-3 text-sm/6 text-text-muted">{member.bio}</p>
						</div>
					</li>
				))
			}
		</ul>
	</div>
</div>
