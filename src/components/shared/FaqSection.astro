---
import plusIcon from "../../assets/icons/plusIcon.svg?raw";
import minusIcon from "../../assets/icons/minusIcon.svg?raw";

interface Faq {
	question: string;
	answer: string;
}

interface Props {
	faqs: readonly Faq[];
}

const { faqs } = Astro.props as Props;
---

<section class="py-16 sm:py-24 bg-section-alt">
	<div class="mx-auto max-w-7xl px-6 lg:px-8">
		<div class="mx-auto max-w-4xl">
			<h2 class="text-4xl font-semibold tracking-tight text-text sm:text-5xl">
				Frequently asked questions
			</h2>
			<dl class="mt-12 divide-y divide-border">
				{
					faqs.map((faq) => (
						<div class="py-6 first:pt-0 last:pb-0">
							<details class="group">
								<summary
									class="
									w-full
									flex justify-between items-start
									text-left
									list-none 
									cursor-pointer"
								>
									<span class="text-base/7 font-semibold text-text">{faq.question}</span>
									<span class="ml-6 flex h-7 items-center text-accent">
										<span
											aria-hidden="true"
											class="size-6 group-open:hidden [&_svg]:size-full"
											set:html={plusIcon}
										/>
										<span
											aria-hidden="true"
											class="hidden size-6 group-open:block [&_svg]:size-full"
											set:html={minusIcon}
										/>
									</span>
								</summary>
								<dd class="mt-3 pr-12">
									<p class="text-base/7 text-text-muted">{faq.answer}</p>
								</dd>
							</details>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>
