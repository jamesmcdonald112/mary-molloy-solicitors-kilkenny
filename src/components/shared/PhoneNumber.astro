---
interface PhoneNumberProps {
	phoneHref: string;
	phoneIcon: string;
	phoneDisplay: string;
	size?: "sm" | "md" | "lg";
	iconHeight?: string;
	variant?: "solid" | "outline";
	weight?: "normal" | "semibold";
	class?: string;
	iconClass?: string;
}

const {
	phoneHref,
	phoneIcon,
	phoneDisplay,
	size = "md",
	iconHeight,
	variant = "solid",
	weight = "semibold",
	class: className = "",
	iconClass = "",
} = Astro.props as PhoneNumberProps;

const sizeMap = {
	sm: { text: "text-sm", iconSize: "h-5" },
	md: { text: "text-sm", iconSize: "h-6" },
	lg: { text: "text-sm sm:text-base", iconSize: "h-8" },
} as const;

const { text, iconSize } = sizeMap[size];
const resolvedIconSize = iconHeight ?? iconSize;
const weightClass = weight === "normal" ? "font-normal" : "font-semibold";
const iconVariantClass =
	variant === "outline"
		? "[&_svg]:fill-none [&_svg]:stroke-current"
		: "[&_svg]:fill-current [&_svg]:stroke-current";
---

<a class={`flex items-center gap-2 transition duration-200 ${weightClass} ${text} ${className}`} href={`tel:${phoneHref}`}>
  <span
    class={`block ${resolvedIconSize} [&_svg]:size-full ${iconVariantClass} ${iconClass}`}
    set:html={phoneIcon}
  />
  {phoneDisplay}</a
>
