---
type Variant = "solid" | "solid-accent" | "solid-inverse" | "outline" | "ghost-dark";
type Size = "sm" | "md" | "lg";

interface ButtonLinkProps {
	href: string;
	variant?: Variant;
	size?: Size;
	block?: boolean;
	icon?: string;
	label?: string; // optional convenience
	endArrow?: boolean;
	class?: string;
}

const {
	href,
	variant = "solid",
	size = "md",
	block = false,
	label,
	icon,
	endArrow = false,
	class: className = "",
} = Astro.props as ButtonLinkProps;

const group = endArrow ? "group" : "";

const base = `
  inline-flex items-center justify-center gap-2
  font-semibold 
	rounded-md shadow-sm
  border
  transition-colors duration-200
  focus-ring
  `;

const sizes: Record<Size, string> = {
	sm: "px-3 py-2 text-sm",
	md: "px-3.5 py-2.5 text-sm",
	lg: "px-3.5 py-2.5 text-sm sm:text-base",
};

const width = block ? "w-full sm:w-auto" : "max-w-fit";

const variants: Record<Variant, string> = {

	// ── Light surface variants ──────────────────────────────────────

	solid: `
		bg-(--brand-500)   hover:bg-accent
		text-white         hover:text-text-on-accent
		border-(--brand-500) hover:border-accent
	`,

	outline: `
		bg-transparent       hover:bg-accent
		text-text            hover:text-text-on-accent
		border-(--brand-500) hover:border-accent
	`,

	// ── Dark/inverse surface variants ──────────────────────────────

	"solid-accent": `
		bg-accent           hover:bg-accent-hover
		text-text-on-accent
		border-accent       hover:border-accent-hover
	`,

	"solid-inverse": `
		bg-white             hover:bg-accent
		text-(--brand-500)   hover:text-text-on-accent
		border-white         hover:border-accent
	`,

	"ghost-dark": `
		bg-transparent
		text-text-on-dark hover:text-accent
		border-transparent
	`,

};

const classes = [group, base, sizes[size], width, variants[variant], className]
	.filter(Boolean)
	.join(" ");
---

<a href={href} class={classes}>
	{icon && <span class="h-4 w-4 [&_svg]:h-full [&_svg]:w-full" set:html={icon} />}
	<slot>{label}</slot>
	{
		endArrow && (
			<span
				aria-hidden="true"
				class="inline-block
          transition-transform duration-200 group-hover:translate-x-1"
			>
				&rarr;
			</span>
		)
	}
</a>
