---
type Variant =
	| "solid"
	| "solid-accent"
	| "solid-inverse"
	| "outline"
	| "ghost-dark";
type Size = "sm" | "md" | "lg";

interface ButtonLinkProps {
	href: string;
	tel?: boolean;
	variant?: Variant;
	size?: Size;
	block?: boolean;
	icon?: string;
	label?: string;
	endArrow?: boolean;
	class?: string;
}

const {
	href,
	tel = false,
	variant = "solid",
	size = "md",
	block = false,
	label,
	icon,
	endArrow = false,
	class: className = "",
} = Astro.props as ButtonLinkProps;

const resolvedHref = tel ? `tel:${href}` : href;

const group = endArrow ? "group" : "";

const base = `
  inline-flex items-center justify-center gap-2
  font-semibold whitespace-nowrap
	rounded-md shadow-sm
  border
  transition-colors duration-200
  focus-ring
  `;

const sizes: Record<Size, string> = {
	sm: "px-3 py-2 text-sm",
	md: "px-3.5 py-2.5 text-base",
	lg: "px-4 py-3 text-lg",
};

const iconSizes: Record<Size, string> = {
	sm: "h-4 w-4",
	md: "h-5 w-5",
	lg: "h-6 w-6",
};

const width = block ? "w-full sm:w-auto" : "max-w-fit";

const variants: Record<Variant, string> = {
	// ── Light surface variants ──────────────────────────────────────

	solid: `
		bg-(--brand-500)   hover:bg-accent-hover
		text-white         hover:text-text-on-accent
		border-(--brand-500) hover:border-accent-hover
	`,

	outline: `
		bg-transparent       hover:bg-accent-hover
		text-text            hover:text-text-on-accent
		border-(--brand-500) hover:border-accent-hover
	`,

	// ── Dark/inverse surface variants ──────────────────────────────

	"solid-accent": `
		bg-accent-dark       hover:bg-accent-dark-hover
		text-text-on-accent
		border-accent-dark   hover:border-accent-dark-hover
	`,

	"solid-inverse": `
		bg-white             hover:bg-accent-hover
		text-(--brand-500)   hover:text-text-on-accent
		border-white         hover:border-accent-hover
	`,

	"ghost-dark": `
		bg-transparent
		text-text-on-dark hover:text-accent
		border-transparent
	`,
};

const classes = [group, base, sizes[size], width, variants[variant], className]
	.filter(Boolean)
	.join(" ");
---

<a href={resolvedHref} class={classes}>
	{icon && <span class={`${iconSizes[size]} [&_svg]:h-full [&_svg]:w-full`} set:html={icon} />}
	<slot>{label}</slot>
	{
		endArrow && (
			<span
				aria-hidden="true"
				class="inline-block
          transition-transform duration-200 group-hover:translate-x-1"
			>
				&rarr;
			</span>
		)
	}
</a>
