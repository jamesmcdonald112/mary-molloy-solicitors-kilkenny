---
interface BrandProps {
	companyLogo: string;
	companyName?: string;
	county?: string;
	href?: string;
	class?: string;
}

const {
	companyLogo,
	companyName,
	county,
	href = "/",
	class: className = "",
} = Astro.props as BrandProps;
---

<a
  href={href}
  aria-label={companyName ? `${companyName} home` : "Home"}
  class=`
    group
    inline-flex items-center gap-2
    -m-1.5 p-1.5
    rounded-md
    focus-ring
    ${className}`
>
  <span
    set:html={companyLogo}
    class="h-14 w-14 [&_svg]:size-full [&_svg_g]:fill-accent
      transition duration-200
      group-hover:scale-105"
  />

  {
    (companyName || county) && (
      <div
        class="
        flex flex-col
        leading-tight"
      >
        {companyName && (
          <span
            class="
            font-semibold text-md text-white
            transition-colors duration-200
            group-hover:text-accent"
          >
            {companyName}
          </span>
        )}
        {county && (
          <span class="text-sm text-text-muted-on-dark transition-colors duration-200 group-hover:text-accent">
            {county}
          </span>
        )}
      </div>
    )
  }
</a>
