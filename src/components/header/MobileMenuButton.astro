---
interface MobileMenuButtonProps {
	icon: string;
	border?: boolean;
	srLabel: string;
	action: "open" | "close";
	controlsId?: string;
	class?: string;
}

const {
	icon,
	border = false,
	srLabel,
	action,
	controlsId = "mobile-menu",
	class: className = "",
} = Astro.props as MobileMenuButtonProps;

const base = [
	"group",
	"lg:hidden",
	"grid place-items-center",
	"p-2.5",
	"bg-transparent",
	"cursor-pointer hover:scale-105 hover:bg-accent",
	"focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent",
	"transition duration-200",
];

const classes = [
	...base,
	border ? "border border-primary-dark-border rounded-md " : "",
	className,
]
	.filter(Boolean)
	.join(" ");
---

<!-- MODAL BUTTON -->
<button
  type="button"
  class={classes}
  aria-controls={controlsId}
  data-action={action}
>
  <span class="sr-only">{srLabel}</span>
  <span
    set:html={icon}
    class="w-6 h-6
    block [&_svg]:size-full
    text-white"
  />
</button>
