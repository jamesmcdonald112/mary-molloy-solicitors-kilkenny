---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { globalCtas } from "../../config/ctas";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
	title: string;
	subtitle: string;
	image: ImageMetadata;
	imageAlt?: string;
	imageClass?: string;
}

const {
	title,
	subtitle,
	image,
	imageAlt = "",
	imageClass = "",
} = Astro.props as Props;
---

<div class="flex flex-col justify-end relative isolate overflow-hidden min-h-[480px] lg:min-h-[540px]">
	<Image
		src={image}
		alt={imageAlt}
		aria-hidden="true"
		widths={[768, 1280, 1920]}
		sizes="100vw"
		class={`absolute inset-0 size-full object-cover ${imageClass}`}
	/>

	<div class="absolute inset-0 bg-black/55" />

	<div class="relative container-page w-full py-16 lg:py-24">
		<div class="max-w-2xl">
			<a
				href="/services"
				class="group
					inline-flex items-center gap-1.5
					text-sm font-semibold text-accent hover:text-white
					rounded-sm transition-colors duration-200 focus-ring"
			>
				<span>Our services</span>
				<span aria-hidden="true" class="inline-block group-hover:translate-x-0.5 transition-transform duration-200">&rarr;</span>
			</a>

			<h1 class="mt-4 text-4xl lg:text-5xl xl:text-6xl font-semibold tracking-tight text-pretty text-white">
				{title}
			</h1>

			<p class="mt-6 text-lg lg:text-xl/8 font-normal text-pretty text-white/80">
				{subtitle}
			</p>

			<div class="mt-10 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-x-4">
				<ButtonLink
					href={globalCtas.call.href}
					size="lg"
					block={true}
					label={globalCtas.call.label}
					icon={globalCtas.call.icon}
				/>
				<ButtonLink
					href={globalCtas.email.href}
					variant="ghost-dark"
					size="lg"
					block={true}
					label={globalCtas.email.label}
					endArrow={true}
				/>
			</div>
		</div>
	</div>
</div>
