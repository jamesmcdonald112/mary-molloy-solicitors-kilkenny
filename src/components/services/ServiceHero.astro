---
import { Image } from "astro:assets";
import { globalCtas } from "../../config/ctas";
import ButtonLink from "../ui/ButtonLink.astro";
import type { ImageMetadata } from "astro";

interface Props {
	title: string;
	subtitle: string;
	image: ImageMetadata;
	imageAlt?: string;
	imageClass?: string;
}

const { title, subtitle, image, imageAlt = "", imageClass = "" } = Astro.props as Props;
---

<div class="relative overflow-hidden">
	<div class="mx-auto max-w-7xl
    lg:grid lg:grid-cols-12
    lg:gap-x-8 lg:px-8">
		<!-- Left panel: text content (7 cols on lg, 6 on xl) -->
		<div
			class="lg:col-span-7 xl:col-span-6
      px-6 lg:px-0
      pt-10 sm:pt-24
      pb-24 sm:pb-24"
		>
			<div class="mx-auto max-w-lg lg:mx-0">
				<!-- "Our services" back link -->
				<a
					href="/services"
					class="group
            inline-flex items-center gap-1.5
            text-sm font-medium text-text-accent
            rounded-sm
            transition-opacity duration-200 hover:opacity-70
            focus-ring"
				>
					<span>Our services</span>
					<span
						aria-hidden="true"
						class="inline-block
              group-hover:translate-x-0.5
              transition-transform duration-200"
						>&rarr;</span
					>
				</a>

				<!-- Page title and subtitle — passed in from the service config -->
				<h1
					class="mt-6
          text-5xl sm:text-7xl
          font-semibold tracking-tight text-pretty text-text"
				>
					{title}
				</h1>

				<p
					class="mt-8
          text-lg sm:text-xl/8
          font-medium text-pretty text-text"
				>
					{subtitle}
				</p>

				<!-- CTAs: call (primary) + email (outline) -->
				<div
					class="mt-10
          flex flex-col sm:flex-row
          sm:items-center
          gap-4 sm:gap-x-4"
				>
					<ButtonLink
						href={globalCtas.call.href}
						size="lg"
						block={true}
						label={globalCtas.call.label}
						icon={globalCtas.call.icon}
					/>
					<ButtonLink
						href={globalCtas.email.href}
						variant="outline"
						size="lg"
						block={true}
						label={globalCtas.email.label}
						endArrow={true}
					/>
				</div>
			</div>
		</div>

		<!-- Right panel: hero image (5 cols on lg, full right half on xl) -->
		<!-- image and imageClass are passed in as props — set per service page -->
		<div
			class="relative xl:absolute xl:inset-0 xl:left-1/2
      lg:col-span-5
      lg:-mr-8 xl:mr-0"
		>
			<div class="h-100 lg:h-full overflow-hidden">
				<Image
					src={image}
					alt={imageAlt}
					class={`h-full w-full object-cover ${imageClass}`}
					widths={[640, 960, 1280]}
					sizes="(max-width: 1024px) 100vw, (max-width: 1280px) 42vw, 50vw"
				/>
			</div>
		</div>
	</div>
</div>
