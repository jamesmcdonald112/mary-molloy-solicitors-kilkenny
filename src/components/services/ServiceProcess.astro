---
/**
 * ServiceProcess — step timeline.
 * bg: section (white) — clean break after the tinted article
 */

interface Step {
	title: string;
	description: string;
}

interface Props {
	steps: readonly Step[];
}

const { steps } = Astro.props as Props;
---

<section class="py-16 sm:py-24">
	<div class="mx-auto
    max-w-7xl
    px-6 lg:px-8">
		<!-- Section header: fixed labels, not configurable -->
		<div class="mx-auto lg:mx-0
      max-w-2xl">
			<p class="eyebrow text-accent">How it works</p>
			<h2 class="mt-3 section-heading">
				What to expect next
			</h2>
		</div>

		<!-- Steps grid: 1 col mobile, 2 col sm, 4 col lg -->
		<!-- steps passed in from the service config as { title, description }[] -->
		<div class="mt-12
      mx-auto
      max-w-2xl lg:max-w-none">
			<ol class="grid
        grid-cols-1 sm:grid-cols-2 lg:grid-cols-4
        gap-8">
				{
					steps.map((step, i) => (
						<li
							class="
              relative 
              flex flex-col"
						>
							<div class="flex items-center gap-4">
								{/* Step number bubble (zero-padded: 01, 02...) */}
								<span
									class="
                  shrink-0
                  flex items-center justify-center
                  size-10  
                  text-sm font-semibold text-on-success
                  bg-success
                  rounded-full "
								>
									{String(i + 1).padStart(2, "0")}
								</span>
								{/* Horizontal connector line — hidden on mobile, visible on lg+, not shown after last step */}
								{i < steps.length - 1 && (
									<div
										class="
                    hidden lg:block
                    h-px 
                    flex-1 
                    bg-border"
										aria-hidden="true"
									/>
								)}
							</div>
							{/* Step title and description */}
							<div class="mt-6">
								<h3 class="text-base font-semibold text-text">{step.title}</h3>
								<p class="mt-2 text-sm/6 text-text-muted">{step.description}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</div>
</section>
