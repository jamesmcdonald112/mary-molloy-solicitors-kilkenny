---

import checkCircleIcon from "../../assets/icons/checkCircleIcon.svg?raw";

type Block =
	| { type: "paragraph"; text: string }
	| { type: "heading"; text: string }
	| { type: "list"; items: readonly { label?: string; text: string }[] }
	| { type: "blockquote"; quote: string; attribution?: string };

interface Props {
	eyebrow?: string;
	title: string;
	intro?: string;
	blocks: readonly Block[];
}

const { eyebrow, title, intro, blocks } = Astro.props as Props;
---

<div class="px-6 lg:px-8
  py-16 sm:py-24
  bg-section-primary-light">
	<div class="mx-auto max-w-3xl">
		{
			eyebrow && (
				<p
					class="
          text-sm font-semibold uppercase tracking-widest text-accent"
				>
					{eyebrow}
				</p>
			)
		}

		<h2
			class="mt-3
      text-4xl sm:text-5xl
      font-semibold tracking-tight text-pretty text-text"
		>
			{title}
		</h2>

		{intro && <p class="mt-6 text-xl/8 text-text-muted">{intro}</p>}

		{/* --- Blocks --- renders each block in order based on its type */}
		<div class="mt-10 max-w-2xl space-y-6">
			{
				blocks.map((block) => {
					// Plain paragraph
					if (block.type === "paragraph") {
						return <p class="text-base/7 text-text-muted">{block.text}</p>;
					}

					// Section heading (h3)
					if (block.type === "heading") {
						return (
							<h3 class="mt-10 text-2xl font-semibold tracking-tight text-text">{block.text}</h3>
						);
					}

					// Bulleted list with checkmark icons — items can have an optional bold label
					if (block.type === "list") {
						return (
							<ul role="list" class="mt-2 space-y-4">
								{block.items.map((item) => (
									<li class="flex gap-x-3">
										{/* Checkmark in circle icon */}
										<span
											aria-hidden="true"
											class="
                        mt-1 
                        shrink-0
                        size-5 [&>svg]:size-5 [&>svg]:fill-current
                        text-success"
											set:html={checkCircleIcon}
										/>
										<span class="text-base/7 text-text-muted">
											{item.label && (
												<strong class="font-semibold text-text">{item.label}. </strong>
											)}
											{item.text}
										</span>
									</li>
								))}
							</ul>
						);
					}

					// Pull quote with an optional attribution line
					if (block.type === "blockquote") {
						return (
							<figure class="mt-8 pl-8 border-l-2 border-accent">
								<blockquote class="text-lg font-semibold text-text">
									<p>"{block.quote}"</p>
								</blockquote>
								{block.attribution && (
									<figcaption class="mt-4 text-sm/6 text-text-subtle">
										{block.attribution}
									</figcaption>
								)}
							</figure>
						);
					}
				})
			}
		</div>
	</div>
</div>
